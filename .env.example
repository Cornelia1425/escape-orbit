# Local development (defaults apply if unset — see src/spacetime/spacetimeConfig.ts)
VITE_SPACETIMEDB_URI=wss://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DATABASE=escape-orbit

# Production (Vercel) — required; set in Vercel → Settings → Environment Variables
# VITE_SPACETIMEDB_URI=wss://maincloud.spacetimedb.com
# VITE_SPACETIMEDB_DATABASE=escape-orbit

# Optional: Chrome Focus Guard extension ID (chrome://extensions → Load unpacked → copy ID)
# VITE_EXTENSION_ID=your_extension_id_from_chrome_extensions
# Or set once in the browser console: localStorage.setItem('escape_orbit_extension_id', 'your_id')
