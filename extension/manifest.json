{
  "manifest_version": 3,
  "name": "Escape Orbit Focus",
  "version": "1.4.2",
  "description": "Block Instagram during Escape Orbit focus missions.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Escape Orbit Focus",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "http://localhost:5174/*",
      "http://localhost:5175/*",
      "http://127.0.0.1:5173/*",
      "http://127.0.0.1:5174/*",
      "http://127.0.0.1:5175/*",
      "https://escape-orbit.vercel.app/*"
    ]
  }
}
